        pelvis_to_trunk_lag_ms: 65, trunk_to_arm_lag_ms: 50, score: 80
      },
      leakage: {
        zone1_sequence: 85, zone2_x_factor: 70, zone3_lead_block: 65,
        zone4_trunk_at_fc: 78, zone5_shoulder_align: 82, zone6_pelvis_brake: 68,
        eli_score: 75,
